---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

interface Props {
  works: { title: string; slug: string; image: ImageMetadata }[]
  mobileSingle?: boolean
}

const { works, mobileSingle = false } = Astro.props
---

<ul
  class='grid grid-cols-2 gap-[5vw] px-20 pt-[120px] pb-[60px] max-md:grid-cols-1 max-md:gap-20 max-md:px-[46px] max-md:pt-[100px]'
>
  {
    works.map(({ title, slug, image }, index) => (
      <li class={mobileSingle && index > 0 ? 'max-md:hidden' : undefined}>
        <a class='hover:opacity-100' href={`/works/${slug}`}>
          <figure class='relative aspect-[14/9] overflow-hidden'>
            <Image
              src={image}
              alt={title}
              widths={[480, 768, 1080]}
              sizes='(max-width: 767px) 90vw, 40vw'
              class='absolute inset-0 h-full w-full object-cover object-[50%_0%] transition-all duration-300 hover:scale-110 hover:opacity-100'
            />
          </figure>
          <h3 class='mt-5 font-roboto uppercase max-md:text-[16px]'>{title}</h3>
        </a>
      </li>
    ))
  }
</ul>
