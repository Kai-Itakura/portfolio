---
import GithubIcon from '@fortawesome/fontawesome-free/svgs/brands/github.svg'
import InstagramIcon from '@fortawesome/fontawesome-free/svgs/brands/instagram.svg'
---

<ul class='mr-10 flex justify-end gap-[3vw] [text-shadow:40px_20px_100px_rgb(7_33_66_/_0.5)] max-md:mr-2.5'>
  <li class='z-[200] text-main'>
    <a href='https://github.com/Kai-Itakura' target='_blank' rel='noopener noreferrer'>
      <GithubIcon class='h-10 w-auto max-md:h-[30px]' fill='currentColor' />
      <span class='sr-only'>GitHub</span>
    </a>
  </li>
  <li class='z-[200] text-main'>
    <a href='https://www.instagram.com/kai_itakura/' target='_blank' rel='noopener noreferrer'>
      <InstagramIcon class='h-10 w-auto max-md:h-[30px]' fill='currentColor' />
      <span class='sr-only'>Instagram</span>
    </a>
  </li>
</ul>
