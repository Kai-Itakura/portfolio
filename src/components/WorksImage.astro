---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import Button from './Button.astro'

interface Props {
  mockUpImage: ImageMetadata
  image1: ImageMetadata
  image2: ImageMetadata
  url: string
}

const { mockUpImage, image1, image2, url } = Astro.props
---

<div class='px-20 py-[100px] max-md:px-6 max-md:pt-5 max-md:pb-[60px]'>
  <figure class='mx-auto w-[90%]'>
    <Image src={mockUpImage} alt='' widths={[768, 1280, 1920]} sizes='90vw' class='h-auto w-full' />
  </figure>
  <ul class='mt-[150px] mb-[100px] flex justify-between max-md:my-[60px]'>
    {
      [image1, image2].map((image) => (
        <li class='relative mx-auto h-[200vw] w-[40%] overflow-hidden [box-shadow:1px_1px_5px_#333]'>
          <Image
            src={image}
            alt=''
            widths={[480, 768, 1080]}
            sizes='40vw'
            class='absolute inset-0 h-full w-full object-cover object-[50%_0%]'
          />
        </li>
      ))
    }
  </ul>
  <Button url={url} />
</div>
